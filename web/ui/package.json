{
  "name": "@crossplane-ui/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Crossplane admin UI — Vue 3 application.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/bzzdevlabs/crossplane-ui"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --build && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . && stylelint \"src/**/*.{vue,css,scss}\"",
    "lint:fix": "eslint . --fix && stylelint \"src/**/*.{vue,css,scss}\" --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "vue-tsc --build --force"
  },
  "dependencies": {
    "@fontsource/lato": "^5.2.7",
    "lucide-vue-next": "^1.0.0",
    "monaco-editor": "^0.55.1",
    "oidc-client-ts": "^3.5.0",
    "pinia": "^3.0.1",
    "vue": "^3.5.13",
    "vue-i18n": "^11.0.0",
    "vue-router": "^5.0.6",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.2.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.2.1",
    "eslint-plugin-vue": "^10.9.0",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.4.2",
    "stylelint": "^17.0.0",
    "stylelint-config-recommended-vue": "^1.6.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.18.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.7"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
