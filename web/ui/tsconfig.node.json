{
  "extends": "@vue/tsconfig/tsconfig.json",
  "include": [
    "vite.config.ts",
    "vitest.config.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "outDir": "./node_modules/.tmp/tsconfig.node",
    "declarationDir": "./node_modules/.tmp/tsconfig.node",
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"]
  }
}
