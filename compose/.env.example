# Copy to .env and tweak if a default port clashes with something already
# running on your machine. `docker compose` reads .env automatically.

# Host ports exposed by docker-compose services.
GATEWAY_HOST_PORT=8080
AUTH_HOST_PORT=8081
DEX_HOST_PORT=5556
UI_HOST_PORT=5173

# Override if you changed the k3d cluster name in Taskfile.yml.
K3D_NETWORK=k3d-crossplane-ui
K3S_SERVER_HOST=k3d-crossplane-ui-server-0

# Leave OIDC_ISSUER_URL empty to run the gateway in dev pass-through
# (no auth, injects a synthetic cluster-admin user — curl-friendly).
# Set it to http://localhost:5556/dex to enforce real OIDC verification;
# OIDC_DISCOVERY_URL then points the gateway to the docker-internal Dex.
OIDC_ISSUER_URL=
OIDC_DISCOVERY_URL=http://dex:5556/dex
OIDC_CLIENT_ID=crossplane-ui
