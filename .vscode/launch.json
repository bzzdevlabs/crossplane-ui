{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug gateway",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/services/gateway/cmd",
      "cwd": "${workspaceFolder}/services/gateway",
      "env": {
        "LOG_LEVEL": "debug",
        "LOG_FORMAT": "text",
        "HTTP_ADDR": ":8080",
        "KUBECONFIG": "${env:HOME}/.kube/config"
      }
    },
    {
      "name": "Debug auth",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/services/auth/cmd",
      "cwd": "${workspaceFolder}/services/auth",
      "env": {
        "LOG_LEVEL": "debug",
        "LOG_FORMAT": "text",
        "HTTP_ADDR": ":8081",
        "KUBECONFIG": "${env:HOME}/.kube/config"
      }
    },
    {
      "name": "Debug UI (Vite)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/web/ui",
      "console": "integratedTerminal"
    }
  ],
  "compounds": [
    {
      "name": "Debug full stack",
      "configurations": ["Debug gateway", "Debug auth", "Debug UI (Vite)"]
    }
  ]
}
